        "last_updated": [
          "\n        ",
          "\n        ",
          "\n        ",
          "\n        ",
          "\n        ",
          "\n        ",
          "\n      "
        ]
      },
      "status": "active",
      "reference_number": "QDi.031",
      "remarks": "Associated with Al-Qaida-related groups in the United Kingdom and other\ncountries. Convicted in absentia in Jordan for involvement in terrorist acts in 1998.\nArrested in Feb. 2001 in the United Kingdom, was further detained between Oct. 2002 and\nMar. 2005 and between Aug. 2005 and Jun. 2008. In custody since Dec. 2008. Deported to\nJordan from the United Kingdom on 7 July 2013 to face terrorism charges. Review pursuant\nto Security Council resolution 1822 (2008) was concluded on 19 Oct. 2009. Review pursuant to Security Council resolution 2368 (2017) was concluded on 4 Dec. 2019. Review pursuant to Security Council resolution 2610 (2021) was concluded on 30 October 2023. INTERPOL-UN Security Council Special Notice web link:https://www.interpol.int/en/How-we-work/Notices/View-UN-Notices-Individuals",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "112283",
          "un:versionNum": "1",
          "un:entityType": "individual"
        }
      }
    },
