    {
      "id": "https://www.ammitto.org/entry/un/QDi.124",
      "entity_id": "https://www.ammitto.org/entity/un/QDi.124",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
