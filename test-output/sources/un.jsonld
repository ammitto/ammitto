        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2008-06-04",
        "effective_date": "2008-06-04",
