      "entity_id": "https://www.ammitto.org/entity/un/TAi.168",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Taliban",
        "code": "TALIBAN"
