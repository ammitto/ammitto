      },
      "status": "active",
      "reference_number": "KPe.011",
      "remarks": "The Korea Heungjin Trading Company is used by KOMID for trading purposes.\nWe suspect it has been involved in supplying missile-related goods to Iran’s Shahid\nHemmat Industrial Group (SHIG). Heungjin has been associated with KOMID, and, more\nspecifically, KOMID’s procurement office. Heungjin has been used to procure an advanced\ndigital controller with applications in missile design. KOMID was designated by the\nCommittee in April 2009 and is the DPRK’s primary arms dealer and main exporter of goods\nand equipment related to ballistic missiles and conventional weapons. The Security\nCouncil designated SHIG in resolution 1737 (2006) as an entity involved in Iran’s\nballistic missile programme.",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "690762",
          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
