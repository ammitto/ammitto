    {
      "id": "https://www.ammitto.org/entry/un/QDe.005",
      "entity_id": "https://www.ammitto.org/entity/un/QDe.005",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2001-10-06",
        "effective_date": "2001-10-06",
        "is_indefinite": true,
        "last_updated": [
