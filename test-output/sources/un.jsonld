      }
    },
    {
      "id": "https://www.ammitto.org/entry/un/CDi.021",
      "entity_id": "https://www.ammitto.org/entity/un/CDi.021",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Democratic Republic of the Congo",
        "code": "DRC"
      },
      "effects": [
