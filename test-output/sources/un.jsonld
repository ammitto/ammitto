    {
      "id": "https://www.ammitto.org/entry/un/TAi.148",
      "entity_id": "https://www.ammitto.org/entity/un/TAi.148",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Taliban",
        "code": "TALIBAN"
