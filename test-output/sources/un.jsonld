    {
      "id": "https://www.ammitto.org/entry/un/QDe.136",
      "entity_id": "https://www.ammitto.org/entity/un/QDe.136",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2013-10-21",
        "effective_date": "2013-10-21",
        "is_indefinite": true,
        "last_updated": [
          "\n        ",
          "\n        ",
          "\n      "
        ]
      },
      "status": "active",
      "reference_number": "QDe.136",
      "remarks": "Terrorist and paramilitary group established by Muhammad Jamal al Kashif (QDi.318) in 2011 and linked to Al-Qaida (QDe.004), Aiman al-Zawahiri (QDi.006), and the leadership of Al-Qaida in the Arabian Peninsula (AQAP) (QDe.129) and the Organization of Al-Qaida in the Islamic Maghreb (AQIM) (QDe.014). Funded and supported by AQAP. Multiple terrorist training camps in Egypt and Libya. Reportedly acquiring weapons, conducting training and establishing terrorist groups in the Sinai, Egypt. Training suicide bombers, foreign fighters and planning terrorist attacks in Egypt, Libya and elsewhere as of Sep. 2013. MJN members were reported to be involved in the attack on the United States Mission in Benghazi, Libya, on 11 Sep. 2012. Review pursuant to Security Council resolution 2253 (2015) was concluded on 21 Feb. 2019. Review pursuant to Security Council resolution 2610 (2021) was concluded on 8 November 2022.  INTERPOL-UN Security Council Special Notice web link:https://www.interpol.int/en/How-we-work/Notices/View-UN-Notices-Individuals",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "3026605",
          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
    {
      "id": "https://www.ammitto.org/entry/un/QDe.137",
      "entity_id": "https://www.ammitto.org/entity/un/QDe.137",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2014-05-14",
        "effective_date": "2014-05-14",
        "is_indefinite": true,
        "last_updated": [
          "\n        ",
          "\n        ",
          "\n        ",
          "\n      "
        ]
      },
      "status": "active",
      "reference_number": "QDe.137",
      "remarks": "Associated with Al-Qaida (QDe.004). Brought Syrian and foreign Al-Qaida in Iraq\n                (QDe.115) and Asbat al-Ansar (QDe.007) fighters, along with other foreign Al-Qaida\n                operatives, to join local elements in Syrian Arab Republic to carry out terrorist\n                and guerrilla operations there. Previously associated with the Islamic State in Iraq\n                and the Levant (ISIL), listed as Al-Qaida in Iraq (QDe.115), and its leader Ibrahim\n                Awwad Ibrahim Ali al-Badri al-Samarrai (QDi.299) but separated from that group in\n                2013. In Jul. 2016, Abu Mohammed Al-Jawlani (QDi.317), the leader of Al-Nusrah Front\n                for the People of the Levant, announced the group had changed its name to Jabhat\n                Fath al-Sham and was no longer affiliated with any external entity. Despite the\n                announcement and attempts to distinguish itself from Al-Nusrah Front for the People\n                of the Levant, the group remains aligned with Al-Qaida and continues to carry out\n                terrorist operations under this new name. In January 2017, Al-Nusrah Front created\n                Hay’at Tahrir al-Sham (HTS) as a vehicle to advance its position in the Syrian\n                insurgency and further its own goals as Al-Qaida’s affiliate in Syria. Previously\n                listed between 30 May 2013 and 13 May 2014 as an aka of Al-Qaida in Iraq (QDe.115).\n                Review pursuant to Security Council resolution 2368 (2017) was concluded on 15 November 2021.            \n             INTERPOL-UN Security Council Special Notice web link:https://www.interpol.int/en/How-we-work/Notices/View-UN-Notices-Individuals",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "6908429",
          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
