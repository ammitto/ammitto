    {
      "id": "https://www.ammitto.org/entry/un/TAi.149",
      "entity_id": "https://www.ammitto.org/entity/un/TAi.149",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Taliban",
        "code": "TALIBAN"
      },
      "effects": [
