    {
      "id": "https://www.ammitto.org/entry/un/TAi.158",
      "entity_id": "https://www.ammitto.org/entity/un/TAi.158",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Taliban",
        "code": "TALIBAN"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
