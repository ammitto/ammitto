    {
      "id": "https://www.ammitto.org/entry/un/CDi.005",
      "entity_id": "https://www.ammitto.org/entity/un/CDi.005",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
