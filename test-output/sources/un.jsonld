          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
    {
      "id": "https://www.ammitto.org/entry/un/QDe.129",
      "entity_id": "https://www.ammitto.org/entity/un/QDe.129",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2010-01-19",
        "effective_date": "2010-01-19",
        "is_indefinite": true,
        "last_updated": [
          "\n        ",
          "\n        ",
          "\n        ",
          "\n        ",
          "\n      "
        ]
      },
      "status": "active",
      "reference_number": "QDe.129",
      "remarks": "AQAP is a regional affiliate of Al-Qaida (QDe.004) and an armed group operating\n                primarily in Arabian Peninsula. Location: Yemen. Alternative location: Saudi Arabia\n                (2004 – 2006). Formed in Jan. 2009 when Al-Qaida in Yemen combined with Saudi\n                Arabian Al-Qaida operatives. Leader of AQAP is Qasim Mohamed Mahdi Al-Rimi\n                (QDi.282). Ansar al-Shari’a was formed in early 2011 by AQAP and has taken\n                responsibility for multiple attacks in Yemen against both government and civilian\n                targets. Review pursuant to Security Council resolution 2368 (2017) was concluded on 15 November 2021. INTERPOL-UN Security Council Special Notice web link:https://www.interpol.int/en/How-we-work/Notices/View-UN-Notices-Individuals",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "2881836",
          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
    {
      "id": "https://www.ammitto.org/entry/un/QDe.130",
      "entity_id": "https://www.ammitto.org/entity/un/QDe.130",
      "authority": {
        "id": "un",
        "name": "United Nations",
        "country_code": "UN"
      },
      "regime": {
        "name": "Al-Qaida",
        "code": "AL_QAIDA"
      },
      "effects": [
        {
          "effect_type": "asset_freeze",
          "scope": "full"
        },
        {
          "effect_type": "travel_ban",
          "scope": "full"
        }
      ],
      "period": {
        "listed_date": "2010-08-06",
        "effective_date": "2010-08-06",
        "is_indefinite": true,
        "last_updated": [
          "\n        ",
          "\n        ",
          "\n      "
        ]
      },
      "status": "active",
      "reference_number": "QDe.130",
      "remarks": "Was established in Afghanistan in 1980. In 1993, Harakat-ul Jihad Islami merged\n                with Harakat ul-Mujahidin (QDe.008) to form Harakat ul-Ansar. In 1997, Harakat-ul\n                Jihad Islami split from Harakat ul-Ansar and resumed using its former name.\n                Operations are in India, Pakistan and Afghanistan. Banned in Pakistan. Review pursuant to Security Council resolution 2368 (2017) was concluded on 24 November 2020. INTERPOL-UN Security Council Special Notice web link:https://www.interpol.int/en/How-we-work/Notices/View-UN-Notices-Individuals",
      "raw_source_data": {
        "source_format": "xml",
        "source_specific_fields": {
          "un:dataId": "2921366",
          "un:versionNum": "1",
          "un:entityType": "entity"
        }
      }
    },
